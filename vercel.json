{
  "version": 2,
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/woanlew2933/janleil3n/sans-fight",
      "destination": "/woanlew2933/janleil3n/sans-fight/index.html"
    },
    {
      "source": "/woanlew2933/janleil3n/sans-fight/",
      "destination": "/woanlew2933/janleil3n/sans-fight/index.html"
    },
    {
      "source": "/((?!api/|woanlew2933/janleil3n/sans-fight|skibidilink/).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
